# =============================================================
# RTVoice 开发/测试环境变量模板（.env.dev.example）
#
# 目标机器：192.168.66.163（NVIDIA RTX 3060 12GB，1Panel 管理）
# 对应 Compose：deployment/docker-compose-dev.yml
#
# 使用方式：
#   cp deployment/.env.dev.example deployment/.env
#   按注释填写所有 [必改] 项
#   docker compose -f /data/RTVoice/deployment/docker-compose-dev.yml up -d
#
# 安全说明：
#   - .env 包含敏感密钥，**绝对不要提交到 git**
# =============================================================

# ─────────────────────────────────────────────────────────────
# [必改] 服务器 IP（开发机 IP）
# ─────────────────────────────────────────────────────────────
SERVER_IP=192.168.66.163

# ─────────────────────────────────────────────────────────────
# [必改] LiveKit 密钥
# 生成方式：python3 -c "import secrets; print(secrets.token_urlsafe(16))"
# ─────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevse

# LiveKit 浏览器连接 URL（内网 dev 机直连，不走 Caddy）
LIVEKIT_PUBLIC_URL=ws://192.168.66.163:7880

# Realtime Server 向客户端下发的 WebSocket 基础 URL
PUBLIC_WS_BASE=wss://192.168.66.163

# ─────────────────────────────────────────────────────────────
# [必改] Token Server API Key（≥32 字符）
# ─────────────────────────────────────────────────────────────
APP_API_KEY=changemechangemechangemechangeme32

# ─────────────────────────────────────────────────────────────
# [必改] 内部服务鉴权 Key（STT/TTS/Realtime 共用，≥32 字符）
# 对应 /data/RTVoice/keys/keys.yaml 中 legacy-default 条目的 secret_hash
# ─────────────────────────────────────────────────────────────
RTVOICE_API_KEY=

# ─────────────────────────────────────────────────────────────
# [必改] Admin Console 登录密码
# ─────────────────────────────────────────────────────────────
RTVOICE_ADMIN_USERNAME=admin
RTVOICE_ADMIN_EMAIL=admin@yanyi.com
RTVOICE_ADMIN_PASSWORD=Cozy@2026

# Admin 会话 cookie 签名密钥（≥32 字符随机值）
# 生成：python3 -c "import secrets; print(secrets.token_hex(32))"
RTVOICE_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────
# [必改] TTS 管理 API Key（注册自定义音色用）
# ─────────────────────────────────────────────────────────────
TTS_ADMIN_API_KEY=

# ─────────────────────────────────────────────────────────────
# 网络绑定
# ─────────────────────────────────────────────────────────────
BIND_HOST=0.0.0.0
LIVEKIT_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881

# GPU 设备（通常是 0）
GPU_DEVICE_ID=0

# ─────────────────────────────────────────────────────────────
# LLM 后端（dev 环境默认：CozyGate → OpenAI gpt-4.1）
# ─────────────────────────────────────────────────────────────
LLM_MODEL_PROD=gpt-4.1
LLM_BASE_URL_PROD=http://192.168.66.41:9090/v1
LLM_API_KEY_PROD=CG-Key-2026-0001

# 备用：宿主 ollama（显存紧张时使用）
# LLM_MODEL_PROD=qwen2.5:7b
# LLM_BASE_URL_PROD=http://host.docker.internal:11434/v1
# LLM_API_KEY_PROD=ollama

# ─────────────────────────────────────────────────────────────
# TTS（CosyVoice 3 GPU 配置）
# ─────────────────────────────────────────────────────────────
TTS_DEFAULT_VOICE=default_zh_female
TTS_DEFAULT_LANG=cmn
TTS_VOICE=default_zh_female
TTS_LANG=cmn

# RTX 3060 12GB：10G TTS + 剩余给 CozyGate/Ollama
TTS_MEM_LIMIT=10G
TTS_CPU_LIMIT=2.0
SKIP_RL_MODEL=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True,max_split_size_mb:256

# ─────────────────────────────────────────────────────────────
# STT（SenseVoice-Small）
# ─────────────────────────────────────────────────────────────
STT_NUM_THREADS=2
STT_FINAL_TIMEOUT_S=10.0
STT_PROVIDER=cpu
# 非量化版精度更高（无幻觉），dev 环境推荐 false
STT_QUANTIZED=false

# ─────────────────────────────────────────────────────────────
# Agent
# ─────────────────────────────────────────────────────────────
AGENT_ROOM=rtvoice-test
AGENT_IDENTITY=rtvoice-agent
AGENT_BACKEND=
AGENT_LLM_MAX_TOKENS=2000
TTS_PIPELINE_CONCURRENCY=2
AGENT_SYSTEM_PROMPT=

# ─────────────────────────────────────────────────────────────
# Realtime 会话参数
# ─────────────────────────────────────────────────────────────
RTVOICE_MAX_CONCURRENT_SESSIONS=5
RTVOICE_SESSION_QUEUE_DEPTH=0
RTVOICE_SESSION_CREATE_TIMEOUT_S=60
RTVOICE_SESSION_IDLE_TIMEOUT_S=120
RTVOICE_SESSION_MAX_LIFETIME_S=3600
RTVOICE_WS_DISCONNECT_GRACE_S=0
RTVOICE_TURN_TIMEOUT_S=60
RTVOICE_MEMORY_MAX_TURNS=6
RTVOICE_DEFAULT_PROMPT=你是语音助手。用中文简短回答（≤2 句）。
RTVOICE_PROMPT_MAX_CHARS=2000
RTVOICE_AUDIT_QUEUE_MAX=1000

# ─────────────────────────────────────────────────────────────
# Auth（API Key 后端）
# ─────────────────────────────────────────────────────────────
RTVOICE_KEYS_BACKEND=yaml
RTVOICE_KEYS_FILE=/data/keys/keys.yaml
RTVOICE_REDIS_URL=redis://redis:6379/0
# dev 环境通过 Caddy 自签证书，HTTPS 仍然有效
RTVOICE_SESSION_COOKIE_SECURE=true

# ─────────────────────────────────────────────────────────────
# CORS / Rate Limit
# ─────────────────────────────────────────────────────────────
RTVOICE_CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=30

# ─────────────────────────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Cozy@2026

# ─────────────────────────────────────────────────────────────
# 日志级别（dev 环境建议 DEBUG 以便排查）
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
