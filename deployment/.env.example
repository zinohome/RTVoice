# =============================================================
# RTVoice 生产部署环境变量模板
#
# 使用方式：
#   cp .env.example .env
#   按注释填写所有 [必改] 项，然后运行 deploy.sh
#
# 安全说明：
#   - .env 包含敏感密钥，**绝对不要提交到 git**
#   - 每次部署生成新密钥，不要跨服务器复用
# =============================================================

# ─────────────────────────────────────────────────────────────
# [必改] 服务器 IP
# 填写部署服务器的局域网 IP（LiveKit ICE candidate 和 Caddy TLS 会用到）
# ─────────────────────────────────────────────────────────────
SERVER_IP=192.168.66.163

# ─────────────────────────────────────────────────────────────
# [必改] LiveKit 密钥
# 生成方式（任选一）：
#   python3 -c "import secrets; print('key:', secrets.token_urlsafe(16)); print('secret:', secrets.token_urlsafe(32))"
#   或运行：bash scripts/gen-secrets.sh
# ─────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevse

# LiveKit 浏览器连接 URL（直接连 LiveKit，不经过 Caddy）
# LAN 部署：ws://SERVER_IP:7880
# 公网部署：wss://your-domain.com
LIVEKIT_PUBLIC_URL=ws://192.168.66.163:7880

# Realtime Server 向客户端下发的 WebSocket 基础 URL
# 格式：wss://SERVER_IP（通过 Caddy 443）
PUBLIC_WS_BASE=wss://192.168.66.163

# ─────────────────────────────────────────────────────────────
# [必改] Token Server API Key（客户端 Bearer 鉴权，≥32 字符）
# 生成：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ─────────────────────────────────────────────────────────────
APP_API_KEY=changemechangemechangemechangeme32

# ─────────────────────────────────────────────────────────────
# [必改] 内部服务鉴权 Key（STT/TTS/Realtime 共用，≥32 字符）
# 生成：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ─────────────────────────────────────────────────────────────
RTVOICE_API_KEY=

# ─────────────────────────────────────────────────────────────
# [必改] Admin Console 登录密码
# ─────────────────────────────────────────────────────────────
RTVOICE_ADMIN_USERNAME=admin
RTVOICE_ADMIN_PASSWORD=rtvoice-admin-password

# Admin 会话 cookie 签名密钥（≥32 字符随机值）
# 生成：python3 -c "import secrets; print(secrets.token_hex(32))"
RTVOICE_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────
# [必改] TTS 管理 API Key（注册/删除自定义音色用，≥32 字符）
# 留空则禁用音色管理功能
# 生成：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ─────────────────────────────────────────────────────────────
TTS_ADMIN_API_KEY=

# ─────────────────────────────────────────────────────────────
# 网络绑定
# ─────────────────────────────────────────────────────────────
BIND_HOST=0.0.0.0
LIVEKIT_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881

# ─────────────────────────────────────────────────────────────
# GPU 设备（nvidia-smi 确认 GPU ID，通常是 0）
# ─────────────────────────────────────────────────────────────
GPU_DEVICE_ID=0

# ─────────────────────────────────────────────────────────────
# LLM（使用宿主 ollama，无需容器内 LLM）
# 确保宿主已安装 ollama 且模型已拉取：ollama pull qwen2.5:7b
# ─────────────────────────────────────────────────────────────
LLM_MODEL_PROD=qwen2.5:7b
LLM_BASE_URL_PROD=http://host.docker.internal:11434/v1

# ─────────────────────────────────────────────────────────────
# TTS（CosyVoice 3 GPU 配置）
# ─────────────────────────────────────────────────────────────
# 默认音色：CosyVoice3 内置中文女声
TTS_DEFAULT_VOICE=default_zh_female
TTS_DEFAULT_LANG=cmn

# Agent Worker 的默认音色（应与 TTS 可用音色一致）
TTS_VOICE=default_zh_female
TTS_LANG=cmn

# TTS 容器显存上限（RTX 3060 12GB 推荐 10G，与 ollama 共存留 2GB 余量）
TTS_MEM_LIMIT=10G
TTS_CPU_LIMIT=2.0

# 跳过 RL 变体（1=跳过省 2GB 显存；0=全量下载）
SKIP_RL_MODEL=1

# CUDA 显存分配策略（防 OOM）
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True,max_split_size_mb:256

# ─────────────────────────────────────────────────────────────
# STT
# ─────────────────────────────────────────────────────────────
STT_NUM_THREADS=2

# ─────────────────────────────────────────────────────────────
# Agent
# ─────────────────────────────────────────────────────────────
AGENT_ROOM=rtvoice-test
AGENT_IDENTITY=rtvoice-agent
AGENT_BACKEND=
AGENT_LLM_MAX_TOKENS=80
TTS_PIPELINE_CONCURRENCY=2

# Agent 系统提示（留空用默认）
AGENT_SYSTEM_PROMPT=

# ─────────────────────────────────────────────────────────────
# Realtime 会话参数
# ─────────────────────────────────────────────────────────────
RTVOICE_MAX_CONCURRENT_SESSIONS=5
RTVOICE_SESSION_QUEUE_DEPTH=0
RTVOICE_SESSION_CREATE_TIMEOUT_S=60
RTVOICE_SESSION_IDLE_TIMEOUT_S=30
RTVOICE_SESSION_MAX_LIFETIME_S=1800
RTVOICE_WS_DISCONNECT_GRACE_S=0
RTVOICE_TURN_TIMEOUT_S=60
RTVOICE_MEMORY_MAX_TURNS=6
RTVOICE_DEFAULT_PROMPT=你是语音助手。用中文简短回答（≤2 句）。
RTVOICE_PROMPT_MAX_CHARS=2000
RTVOICE_AUDIT_QUEUE_MAX=1000

# ─────────────────────────────────────────────────────────────
# Auth（API Key 后端）
# ─────────────────────────────────────────────────────────────
RTVOICE_KEYS_BACKEND=yaml
RTVOICE_KEYS_FILE=/data/keys/keys.yaml
RTVOICE_REDIS_URL=redis://redis:6379/0
RTVOICE_SESSION_COOKIE_SECURE=true

# ─────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────
# 仅内网用 * 即可；上公网建议改为具体域名
RTVOICE_CORS_ORIGINS=*

# ─────────────────────────────────────────────────────────────
# Rate Limit
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ─────────────────────────────────────────────────────────────
# Grafana 监控面板
# ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ─────────────────────────────────────────────────────────────
# 日志级别
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
