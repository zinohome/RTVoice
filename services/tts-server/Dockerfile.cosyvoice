# tts-server CosyVoice 2 GPU 变体（v0.6.0）
#
# CosyVoice 2-0.5B GPU 推理：中文 SOTA TTS，质量明显优于 Kokoro
# 协议层与 Kokoro 版完全相同：POST /tts/stream → chunked PCM 24kHz int16 mono
# agent 端零改动；切换路径走 docker-compose.prod.yml 的 image 选择
#
# 镜像大小预估：~10GB（CUDA base + python + torch + CosyVoice deps）
# 模型文件 ~5GB 不打包进镜像，runtime 自动下载到 named volume

# 用 devel 镜像（带 nvcc + CUDA toolkit）而非 runtime
# CosyVoice 依赖 deepspeed 0.15.1，import 时调 nvcc -V 探测 CUDA 版本；
# runtime 镜像没 nvcc → FileNotFoundError 让整个 import 链断
# devel 镜像多 ~2GB，但能保证 deepspeed + 任何 JIT 编译路径稳定
FROM nvidia/cuda:12.6.3-devel-ubuntu24.04

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive \
    COSYVOICE_DIR=/opt/CosyVoice \
    MODEL_DIR=/opt/CosyVoice/pretrained_models/CosyVoice2-0.5B

# 系统依赖
# 注：CosyVoice requirements.txt 里很多包（grpcio==1.57, lhotse, pyworld 等）
# 在 Python 3.12 上没 cp312 wheel，CosyVoice 项目本身原生在 3.10 上测试。
# 用 deadsnakes PPA 装 Python 3.10 而非用 24.04 默认 3.12，避免大量兼容陷阱。
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    git wget curl ca-certificates \
    sox libsox-dev \
    build-essential pkg-config \
 && add-apt-repository -y ppa:deadsnakes/ppa \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
    python3.10 python3.10-venv python3.10-dev \
 && rm -rf /var/lib/apt/lists/*

# venv 用 Python 3.10（CosyVoice 原生兼容版本）
RUN python3.10 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# 关键：用 setuptools<70 因为 setuptools 70+ 移除了 pkg_resources（独立化），
# 而 CosyVoice 依赖（如 openai-whisper==20231117）的 setup.py 还 import 它。
# build isolation 创建的子环境也要装这个旧 setuptools——靠 PIP_BUILD_CONSTRAINT。
RUN python -m pip install --upgrade pip \
 && pip install 'setuptools<70' wheel \
 && echo "setuptools<70" > /tmp/build-constraints.txt
ENV PIP_BUILD_CONSTRAINT=/tmp/build-constraints.txt
ENV PIP_CONSTRAINT=/tmp/build-constraints.txt

# Clone CosyVoice + Matcha-TTS submodule
WORKDIR /opt
RUN git clone --depth 1 --recurse-submodules \
    https://github.com/FunAudioLLM/CosyVoice.git CosyVoice \
 && cd CosyVoice && git log --oneline | head -1

WORKDIR /opt/CosyVoice

# CosyVoice 自身依赖（torch、transformers、diffusers、conformer、hyperpyyaml 等）
# 注：requirements.txt 里 torch 默认是 cu121，对 12.6 base 也兼容（向下）
RUN pip install -r requirements.txt

# 我们的 server wrapper deps（FastAPI + Prometheus + 我们的协议）
COPY requirements.cosyvoice.txt /tmp/server-requirements.txt
RUN pip install -r /tmp/server-requirements.txt

# 我们的服务代码
WORKDIR /app
COPY app /app/app

# 入口脚本：首次运行下载模型（~5GB → named volume，重启秒起）
COPY entrypoint-cosyvoice.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# 非 root（24.04 base 已占 uid 1000=ubuntu）
RUN useradd -u 1001 -m appuser \
 && chown -R appuser:appuser /app /opt/venv /opt/CosyVoice
USER appuser

EXPOSE 9880

# 健康检查：模型加载完毕（recognizer ready）
HEALTHCHECK --interval=15s --timeout=5s --retries=10 --start-period=600s \
  CMD python -c "import urllib.request,json,sys; r=json.load(urllib.request.urlopen('http://127.0.0.1:9880/health',timeout=3)); sys.exit(0 if r.get('status')=='ok' else 1)" \
    || exit 1

ENTRYPOINT ["/entrypoint.sh"]
CMD ["uvicorn", "app.main_cosyvoice:app", "--host", "0.0.0.0", "--port", "9880"]
