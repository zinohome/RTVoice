{
  "schemaVersion": 39,
  "version": 1,
  "uid": "rtvoice-overview",
  "title": "RTVoice — Voice Agent Overview",
  "tags": ["rtvoice", "voice-agent"],
  "timezone": "browser",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "10s",
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Global Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Agent FSM State",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "label_replace(rtvoice_agent_state == 1, \"current\", \"$1\", \"state\", \"(.+)\")",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": []
        }
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Active STT WS",
      "gridPos": { "x": 6, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "rtvoice_stt_ws_connections_active", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "gray", "value": null }, { "color": "green", "value": 1 } ] } } }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Rounds (24h)",
      "gridPos": { "x": 10, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "increase(rtvoice_agent_rounds_total[24h])", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Barge-ins (24h)",
      "gridPos": { "x": 14, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "increase(rtvoice_agent_barge_ins_total[24h])", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Pipeline Errors (24h)",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "increase(rtvoice_agent_pipeline_errors_total[24h])", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } } }
    },

    {
      "type": "row",
      "id": 10,
      "title": "Agent — End-to-End Latency",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Round duration (p50/p95)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(rtvoice_agent_round_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(rtvoice_agent_round_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "First-audio latency (perceived TTFB) — p50/p95",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(rtvoice_agent_first_audio_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(rtvoice_agent_first_audio_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Phrases per round (avg)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(rtvoice_agent_round_phrases_sum[5m]) / rate(rtvoice_agent_round_phrases_count[5m])", "legendFormat": "avg", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "STT events / barge-ins",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(rtvoice_agent_stt_finals_total[5m])", "legendFormat": "STT final/s", "refId": "A" },
        { "expr": "rate(rtvoice_agent_stt_partials_total[5m])", "legendFormat": "STT partial/s", "refId": "B" },
        { "expr": "rate(rtvoice_agent_barge_ins_total[5m])", "legendFormat": "barge-in/s", "refId": "C" }
      ]
    },

    {
      "type": "row",
      "id": 20,
      "title": "STT — sherpa-onnx",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Decode latency (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(rtvoice_stt_decode_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(rtvoice_stt_decode_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(rtvoice_stt_decode_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "WS connections + event types",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rtvoice_stt_ws_connections_active", "legendFormat": "active", "refId": "A" },
        { "expr": "rate(rtvoice_stt_events_total[5m])", "legendFormat": "{{type}}", "refId": "B" }
      ]
    },

    {
      "type": "row",
      "id": 30,
      "title": "TTS — Kokoro / CosyVoice",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 31,
      "title": "Phrase synth rate / failure rate",
      "gridPos": { "x": 0, "y": 29, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(rtvoice_tts_phrases_total[5m])", "legendFormat": "ok/s", "refId": "A" },
        { "expr": "rate(rtvoice_tts_failures_total[5m])", "legendFormat": "fail/s", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "id": 32,
      "title": "TTFB p50/p95",
      "gridPos": { "x": 8, "y": 29, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(rtvoice_tts_ttfb_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(rtvoice_tts_ttfb_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "id": 33,
      "title": "Phrase RTF (>1 = faster than realtime)",
      "gridPos": { "x": 16, "y": 29, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(rtvoice_tts_phrase_rtf_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.05, sum(rate(rtvoice_tts_phrase_rtf_bucket[5m])) by (le))", "legendFormat": "p5 (worst)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1.0 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },

    {
      "type": "row",
      "id": 40,
      "title": "Token Server",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Tokens issued / auth failures",
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(rtvoice_tokens_issued_total[5m])) by (room)", "legendFormat": "issued ({{room}})/s", "refId": "A" },
        { "expr": "sum(rate(rtvoice_token_auth_failures_total[5m])) by (reason)", "legendFormat": "401 ({{reason}})/s", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "id": 42,
      "title": "HTTP request duration p50/p95",
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(http_request_duration_seconds_bucket{job=\"rtvoice-token\"}[5m])) by (le, handler))", "legendFormat": "{{handler}} p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"rtvoice-token\"}[5m])) by (le, handler))", "legendFormat": "{{handler}} p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
