# RTVoice Python quickstart sample — env config

# RTVoice ingress URL (Caddy)。LAN 自签场景默认 https://192.168.66.163
RTVOICE_BASE_URL=https://192.168.66.163

# Caddy 自签 root CA 路径。run scripts/get-rtvoice-ca.sh 拉到本地。
# 留空 = 不验证证书（仅自测；生产必须填）
RTVOICE_CA_FILE=../../caddy-root.crt

# admin CLI 颁发的 key secret（注意：secret 只显示一次，立刻保存）
RTVOICE_API_KEY=REPLACE_WITH_YOUR_KEY_SECRET

# 测试 room 名（任意）
DEMO_ROOM=quickstart-demo
DEMO_IDENTITY=alice
