# =============================================================
# RTVoice 环境变量模板
# 用法：
#   cp .env.example .env
#   填入实际值
# 安全：
#   .env 已在 .gitignore，绝对不要提交
#   生产机和开发机使用各自的 .env，互不复用 LIVEKIT_API_SECRET
# =============================================================

# --- 项目 ---
COMPOSE_PROJECT_NAME=rtvoice

# --- 部署环境 ---
# dev | prod
RTVOICE_ENV=dev

# --- LiveKit 鉴权 ---
# 生成方式（先临时跑一次）:
#   docker run --rm livekit/livekit-server:v1.7.2 generate-keys
# 或使用 livekit-cli:
#   livekit-cli generate-keys
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevse

# --- token-server 访问鉴权 ---
# 客户端调 POST /token 必须带 Authorization: Bearer <APP_API_KEY>
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
# 或：openssl rand -base64 32
# 必须 ≥ 32 字符。dev 阶段也别用弱值，养成习惯。
APP_API_KEY=changemechangemechangemechangeme32

# --- 网络绑定 ---
# 开发机：永远 127.0.0.1，仅本机访问
# 生产机：用户决策；公网开放需明确改为 0.0.0.0 并开防火墙
BIND_HOST=127.0.0.1

# --- 端口 ---
LIVEKIT_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
# dev 默认 50000-50009（10 个端口足够本机调试）
# prod compose override 会用 50000-50099（100 个，应对真实并发）
LIVEKIT_RTC_UDP_PORT_START=50000
LIVEKIT_RTC_UDP_PORT_END=50009
TOKEN_SERVER_PORT=8000

# --- 内部服务端口（仅 docker network 内可见，不映射宿主） ---
STT_SERVER_PORT=9090
TTS_SERVER_PORT=9880
LLM_SERVER_PORT=8001

# --- GPU 配置（仅 prod profile 使用） ---
# 设备 ID 列表，逗号分隔。用 nvidia-smi 查 ID。默认仅 0 号卡。
GPU_DEVICE_IDS=0

# --- agent-worker ---
AGENT_ROOM=rtvoice-test
AGENT_IDENTITY=rtvoice-agent

# --- 模型选型（dev / prod 各自填） ---
# dev 默认 mock，prod 默认 CosyVoice 2
TTS_ENGINE=mock
# dev sherpa-onnx-cpu / prod sherpa-onnx-gpu
STT_ENGINE=sherpa-onnx-cpu
# dev mock / prod vllm / 也可 ollama
LLM_BACKEND=mock
LLM_MODEL=Qwen/Qwen2.5-3B-Instruct

# --- 日志级别 ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# --- 可选：Ollama URL（如果 LLM_BACKEND=ollama） ---
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- 可选：HuggingFace 镜像（国内加速） ---
# HF_ENDPOINT=https://hf-mirror.com
