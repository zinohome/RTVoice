# ============================================================
# 国内部署提示：docker.io 限速，建议配 registry-mirrors
# 详见 OPERATIONS.md §6
# ============================================================

# =============================================================
# RTVoice 环境变量模板
#
# 用法：
#   cp .env.example .env
#   按下面注释填值（标 [必改] 的必须）
#
# 安全：
#   .env 已在 .gitignore，**绝对不要提交**
#   生产机和开发机使用各自的 .env，互不复用 SECRET / KEY
# =============================================================

# --- 项目 ---
COMPOSE_PROJECT_NAME=rtvoice

# --- 部署环境 ---
# dev | prod  (用于人类阅读；compose 切换实际靠 -f compose.{dev|prod}.yml)
RTVOICE_ENV=dev

# ============================================================
# [必改] 鉴权密钥（dev 也别用默认值）
# ============================================================

# LiveKit 服务端密钥（让 token-server 签 JWT）
# 生成方式（任选一）：
#   docker run --rm livekit/livekit-server:v1.11.0 generate-keys
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"  # 用作 secret
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevse

# token-server 访问鉴权（客户端 Bearer header）
# **必须 ≥ 32 字符**。生成：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APP_API_KEY=changemechangemechangemechangeme32

# ============================================================
# 网络绑定
# ============================================================

# dev：127.0.0.1（仅本机）
# prod：[必改] 0.0.0.0 或具体外网 IP；公网开放需配防火墙
BIND_HOST=127.0.0.1

# 浏览器侧用的 LiveKit URL
# dev: ws://127.0.0.1:7880   prod: [必改] wss://your-domain.example.com
LIVEKIT_PUBLIC_URL=ws://127.0.0.1:7880

# LiveKit 对外宣告的 IP（WebRTC ICE candidate）
# LAN 部署：填服务器 LAN IP（必须等于浏览器访问的 IP）
# 公网部署：填公网 IP；或留空走 use_external_ip=true（需改 livekit.prod.yaml）
# dev：留空（dev override 不读这个变量，且 dev 全 127.0.0.1 不需要）
RTVOICE_NODE_IP=

# 端口（dev 默认；prod 由用户决定是否暴露）
LIVEKIT_PORT=7880
LIVEKIT_RTC_TCP_PORT=7881
TOKEN_SERVER_PORT=8000

# UDP 媒体端口范围
# dev：50000-50009（10 个）  prod：50000-50099（100 个，需打开防火墙）
LIVEKIT_RTC_UDP_PORT_START=50000
LIVEKIT_RTC_UDP_PORT_END=50009

# 内部服务端口（仅 docker network 内可见）
STT_SERVER_PORT=9090
TTS_SERVER_PORT=9880
LLM_SERVER_PORT=8001

# ============================================================
# STT/TTS 对外鉴权（v0.6.1 — 给"另一个项目"调用 stt/tts 用）
# ============================================================
# 留空 = 鉴权关闭（dev 默认）；非空 = 三个 server 全启用 Bearer 校验
# 生成：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 客户端用法：
#   STT WS:  ws://host:9090/asr  + header "Authorization: Bearer <KEY>"
#            或 subprotocol "bearer.<KEY>"，或 ?token=<KEY>
#   TTS HTTP: POST http://host:9880/tts/stream
#            -H "Authorization: Bearer <KEY>"
RTVOICE_API_KEY=

# 暴露 STT/TTS 给 LAN/公网：用 docker-compose.api.yml override
# STT_API_PORT=9090
# TTS_API_PORT=9880

# TLS：用 docker-compose.tls.yml + caddy/Caddyfile（自动 cert）

# ============================================================
# Rate limit (token-server)
# ============================================================
# 每 IP 每分钟最多请求次数（防 API key 泄露被刷）
RATE_LIMIT_PER_MINUTE=30

# ============================================================
# Agent
# ============================================================
AGENT_ROOM=rtvoice-test
AGENT_IDENTITY=rtvoice-agent

# Agent 的 LLM system prompt（留空 = 默认 30 字短回复）
# 改这个不需要 rebuild 镜像，docker compose up -d agent-worker 重启即可。
# 流式 TTS 已开启（token→句切分→并发合成→顺序播放），所以加长回复不会拖慢首字节延迟。
# 例：让回复更长/更自然
# AGENT_SYSTEM_PROMPT=你是 RTVoice 语音助手，用中文自然口语回答，不要用任何符号或 markdown，回答控制在两到三句。
# LLM 输出 token 上限（语音回复 80 够；调长 prompt 时可加大到 200-400）
AGENT_LLM_MAX_TOKENS=80

# v0.6 (experimental) livekit-agents 框架后端切换
# 留空（=v05）= 自写 FSM（已验证可工作）
# v06 = livekit-agents AgentSession（autonomous worker 已注册 LiveKit；真音频未验证）
AGENT_BACKEND=

# ============================================================
# TTS pipeline (v0.5.1)
# ============================================================
# LLM 流式 → 句切分 → 多 phrase 并发合成 → 顺序播放
# 1=串行，2-3=并行隐藏间隙（CPU 强或 GPU 才有效）
TTS_PIPELINE_CONCURRENCY=2

# TTS 音色（Kokoro: zf_*/zm_*；CosyVoice 2: 中文女/中文男 等）
TTS_VOICE=zf_xiaobei
TTS_LANG=cmn

# TTS 后端切换（v0.6+）
# 默认 Kokoro CPU：保持 TTS_IMAGE 注释，使用 docker-compose 默认
# 切 CosyVoice 2 GPU：取消注释下面三行
# TTS_DOCKERFILE=Dockerfile.cosyvoice
# TTS_IMAGE=rtvoice/tts-server-cosyvoice:v0.6.0
# TTS_VOICE=中文女         # CosyVoice SFT 音色名（中文女/中文男/英文女 等）
# TTS_MEM_LIMIT=8G         # CosyVoice 模型 ~5GB + 推理 buffer
# TTS_CPU_LIMIT=2.0

# 切 Fun-CosyVoice 3 GPU（v0.7+，双向流式 150ms 端到端延迟）：
# TTS_DOCKERFILE=Dockerfile.cosyvoice3
# TTS_IMAGE=rtvoice/tts-server-cosyvoice3:v0.7.0
# TTS_MEM_LIMIT=10G        # v3 模型 ~5.6GB + 推理 buffer
# 需要 RL-tuned 变体（多占 2GB）：取消下行注释
# SKIP_RL_MODEL=0

# CosyVoice admin endpoints (POST/DELETE /voices/...) 的 Bearer token
# 留空 = 禁用 admin（默认）；设置后才能注册/删除自定义音色
# 生成：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 用法：
#   curl -X POST http://tts-server:9880/voices/add \
#     -H "Authorization: Bearer <TTS_ADMIN_API_KEY>" \
#     -F spk_id=my_voice -F prompt_text="参考文本" -F file=@ref.wav
# TTS_ADMIN_API_KEY=
# TTS_MAX_WAV_BYTES=5242880   # 上传 wav 大小上限（5MB 默认）

# ============================================================
# LLM
# ============================================================
# dev (ollama)：qwen2.5:1.5b（默认）/ qwen2.5:0.5b（更快）/ qwen2.5:3b（更好但 CPU 慢）
# prod (vLLM)：通过 LLM_MODEL_PROD 控制，下行
LLM_MODEL=qwen2.5:1.5b
OLLAMA_KEEP_ALIVE=5m

# prod LLM 路径（默认走宿主 ollama，零额外服务；vLLM 见末尾）
LLM_MODEL_PROD=qwen2.5:7b
LLM_BASE_URL_PROD=http://host.docker.internal:11434/v1

# LLM 超时分层（httpx 语义）；默认值通常够用，慢机/cold start 调大
# LLM_CONNECT_TIMEOUT_S=10    # TCP 连接超时
# LLM_READ_TIMEOUT_S=30       # 两次数据间隔；流式 = per-chunk timeout

# LLM 异常或 0 token 时的兜底回复（避免 agent 沉默）
# LLM_FALLBACK_REPLY=抱歉，我现在没听清楚，麻烦再说一次。

# STT 长连接重连参数（v0.6.2）
# STT_CONNECT_RETRIES=5              # 初次连接 + 自动重连各最多尝试次数
# STT_CONNECT_BACKOFF_INITIAL_S=1.0  # 退避起始
# STT_CONNECT_BACKOFF_MAX_S=16.0     # 退避封顶

# 如果你想用 vLLM（profile=prod-vllm）替代宿主 ollama：
# LLM_MODEL_PROD=Qwen/Qwen2.5-3B-Instruct-GPTQ-Int4
# LLM_BASE_URL_PROD=http://llm-server:8000/v1
# VLLM_GPU_MEM_UTIL=0.4
# VLLM_MAX_MODEL_LEN=4096

# ============================================================
# GPU (prod only)
# ============================================================
# nvidia-smi 看 GPU ID
GPU_DEVICE_ID=0

# ============================================================
# 杂项
# ============================================================
LOG_LEVEL=INFO         # DEBUG/INFO/WARNING/ERROR
DEV_AUTO_INJECT_KEY=true   # dev=true（测试页自填 key）；prod=false（强制）

# 国内 HF 镜像（若 vLLM 拉模型慢可启用）
# HF_ENDPOINT=https://hf-mirror.com

# ============================================================
# Realtime Voice Service (SP2, v0.9+)
# ============================================================
# 公网 WS URL base（POST /v1/sessions response 里的 ws_url 用此 base）
# dev: ws://realtime-server:9000  prod: wss://your-domain.com
# PUBLIC_WS_BASE=ws://realtime-server:9000

# 并发与生命周期参数（默认调优 RTX 3060 12GB）
# 单 GPU 12GB (3060/4060)：默认值
# 单 GPU 24GB (3090/4090)：MAX_CONCURRENT_SESSIONS=10
# 多 GPU box：等 SP6+ GPU 调度后再说
RTVOICE_MAX_CONCURRENT_SESSIONS=5
RTVOICE_SESSION_QUEUE_DEPTH=0
RTVOICE_SESSION_CREATE_TIMEOUT_S=60
RTVOICE_SESSION_IDLE_TIMEOUT_S=30
RTVOICE_SESSION_MAX_LIFETIME_S=1800
RTVOICE_WS_DISCONNECT_GRACE_S=0
RTVOICE_TURN_TIMEOUT_S=60

# Forward-compatibility hooks（v1 暂不生效）
# RTVOICE_TTS_MODEL_REPLICAS=1     未来 24GB+ 可设 2，并发 TTS 翻倍
# RTVOICE_LLM_MAX_CONCURRENT=4

# ============================================================
# Realtime Voice — SP3 (v0.10+)
# ============================================================
RTVOICE_MEMORY_MAX_TURNS=6
RTVOICE_DEFAULT_PROMPT=你是语音助手。用中文简短回答（≤2 句）。
RTVOICE_PROMPT_MAX_CHARS=2000

# Audit (transcript JSONL persistence)
RTVOICE_AUDIT_DIR=/data/transcripts
RTVOICE_AUDIT_QUEUE_MAX=1000
# Host 路径（compose volume），默认 ./data/transcripts；prod 改 /var/data/rtvoice/transcripts
RTVOICE_AUDIT_HOST_DIR=./data/transcripts

# ============================================================
# CORS (SP5)
# ============================================================
# 默认 * 是 demo/dev 友好；prod 收紧示例：
# RTVOICE_CORS_ORIGINS=https://app.example.com,https://demo.example.com
RTVOICE_CORS_ORIGINS=*

# ============================================================
# Monitoring (SP4 A-lite, profile=monitoring 启用)
# ============================================================
# 启用：docker compose --profile prod --profile monitoring up -d
# Anonymous Grafana 默认 ON；上公网必须加 reverse proxy 鉴权或改 BIND_HOST=127.0.0.1
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================
# Multi-tenant Auth (SP6, v0.13+)
# ============================================================
# backend: yaml (dev) or redis (prod)
RTVOICE_KEYS_BACKEND=yaml

# YAML file path (in container) + host mapping
RTVOICE_KEYS_FILE=/data/keys.yaml
RTVOICE_KEYS_HOST_FILE=./data/keys.yaml

# Redis backend (profile=auth-redis enable)
RTVOICE_REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# Enable Redis:
#   docker compose --profile prod --profile auth-redis up -d
